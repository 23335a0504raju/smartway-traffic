<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <vType id="car" accel="2.6" decel="4.5" sigma="0.5" length="5" minGap="2.5" maxSpeed="40" guiShape="passenger"/>
    <vType id="truck" accel="1.2" decel="2.5" sigma="0.5" length="12" minGap="2.5" maxSpeed="25" guiShape="truck"/>
    <vType id="bus" accel="1.2" decel="2.5" sigma="0.5" length="14" minGap="2.5" maxSpeed="20" guiShape="bus"/>
    <vType id="motorcycle" accel="4.0" decel="6.0" sigma="0.5" length="2" minGap="2.5" maxSpeed="50" guiShape="motorcycle"/>
    <vType id="ambulance" accel="3.0" decel="4.5" sigma="0.5" length="6" minGap="2.5" maxSpeed="60" guiShape="emergency" color="red">
        <param key="has.bluelight.device" value="true"/>
    </vType>

    <!-- Define continuous routes including the internal junction transit edge to prevent visual teleportation -->
    <route id="route_NS" edges="E_North_In :J0_0 E_South_Out"/>
    <route id="route_WE" edges="E_East_In :J0_1 E_West_Out"/>
    <route id="route_SN" edges="E_South_In :J0_2 E_North_Out"/>
    <route id="route_EW" edges="E_West_In :J0_3 E_East_Out"/>

    <!-- Traffic Flows -->
    <flow id="f_NS_car" type="car" begin="0" end="3600" number="800" route="route_NS"/>
    <flow id="f_NS_truck" type="truck" begin="0" end="3600" number="100" route="route_NS"/>
    
    <flow id="f_WE_car" type="car" begin="0" end="3600" number="700" route="route_WE"/>
    <flow id="f_WE_bus" type="bus" begin="0" end="3600" number="50" route="route_WE"/>

    <flow id="f_SN_car" type="car" begin="0" end="3600" number="600" route="route_SN"/>
    <flow id="f_SN_motorcycle" type="motorcycle" begin="0" end="3600" number="200" route="route_SN"/>
    
    <flow id="f_EW_car" type="car" begin="0" end="3600" number="750" route="route_EW"/>

    <!-- Early initial ambulances so the user doesn't have to wait -->
    <flow id="amb_1" type="ambulance" begin="5" end="10" number="1" route="route_NS"/>
    <flow id="amb_2" type="ambulance" begin="25" end="30" number="1" route="route_EW"/>
    
    <!-- Distributed ambulances -->
    <flow id="amb_fleet" type="ambulance" begin="50" end="3600" probability="0.02" route="route_WE"/>

</routes>
